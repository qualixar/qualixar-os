{
  "name": "qualixar-os",
  "version": "2.2.2",
  "description": "Qualixar OS: The Universal OS for AI Agents. One platform, every model, every framework, every transport.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "qos": "./bin/qos.js",
    "qualixar-os": "./bin/qos.js"
  },
  "scripts": {
    "build": "tsc && npm run build:dashboard",
    "build:dashboard": "cd dashboard && npm run build",
    "dev": "tsx src/channels/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run tests/e2e/",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@hono/node-server": "^1.19.12",
    "@inquirer/prompts": "^8.3.2",
