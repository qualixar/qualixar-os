    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/sdk-node": "^0.214.0",
    "better-sqlite3": "^11.0.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "dockerode": "^4.0.10",
    "fast-json-patch": "^3.1.1",
    "hono": "^4.12.9",
    "javascript-lp-solver": "^1.0.3",
    "jsonrepair": "^3.13.3",
    "open": "^11.0.0",
    "openai": "^6.33.0",
    "partial-json": "^0.1.7",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "ws": "^8.20.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/sdk-trace-node": "^2.6.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/d3": "^7.4.3",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.0",
    "d3": "^7.9.0",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.15.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.0",
    "zustand": "^5.0.12"
  },
  "optionalDependencies": {
    "discord.js": "^14.25.1",
    "grammy": "^1.41.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "orchestration",
    "multi-agent",
    "claude",
